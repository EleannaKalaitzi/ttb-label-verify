# Copy to .env and fill in. .env is gitignored — never commit a real key.

# Anthropic API key for the real extraction path (Claude Haiku).
# Get one at https://console.anthropic.com. Not needed in mock mode.
ANTHROPIC_API_KEY=sk-ant-...

# Set to 1 to run with canned extractions and NO API key / no network.
# Lets a reviewer clone, install, and see the app work immediately.
# MOCK_EXTRACTION=1
